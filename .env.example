# === ОБЯЗАТЕЛЬНЫЕ ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_token_from_botfather
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Railway автоматически создаст эти переменные при добавлении PostgreSQL и Redis:
# DATABASE_URL=postgresql+asyncpg://...
# REDIS_URL=redis://...

# === ОПЦИОНАЛЬНЫЕ ===
# Ограничить доступ к боту (ID пользователей через запятую)
# ALLOWED_USERS=123456789,987654321

# Модели (бесплатные)
DEFAULT_MODEL=deepseek/deepseek-chat
SUMMARIZER_MODEL=google/gemma-2-9b-it:free

# Лимиты
MAX_STEPS_PER_TASK=10
MAX_CONTEXT_MESSAGES=15
DAILY_REQUEST_LIMIT=200
